# Copy this file to `.env` and fill in the values. `.env` is gitignored and is
# loaded automatically in development by config/runtime.exs. In production, set
# these as real environment variables instead.

# Google OAuth (Phase 2) — the Client secret from the Google Cloud Console.
# The Client ID is public and lives in config/runtime.exs.
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google emails allowed to sign in as admin.
# Example: ADMIN_GOOGLE_EMAILS=you@gmail.com,you@yourdomain.com
ADMIN_GOOGLE_EMAILS=
