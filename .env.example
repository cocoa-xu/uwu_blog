# Copy this file to `.env` and fill in the values. `.env` is gitignored and is
# loaded automatically in development by config/runtime.exs. In production, set
# these as real environment variables instead.

# Google OAuth (Phase 2) — the Client secret from the Google Cloud Console.
# The Client ID is public and lives in config/runtime.exs.
GOOGLE_CLIENT_SECRET=

# Comma-separated list of Google emails allowed to sign in as admin.
# Example: ADMIN_GOOGLE_EMAILS=you@gmail.com,you@yourdomain.com
ADMIN_GOOGLE_EMAILS=

# --- Clustering (prod, over the tailnet) ---------------------------------
# Setting DNS_CLUSTER_QUERY turns on clustering: the node starts distributed
# (named uwu_blog@<its-Tailscale-IP>) and DNSCluster connects to every IP the
# query resolves to. Point it at a DNS name whose A records list each node's
# Tailscale IP (100.x.y.z). See lib/uwu_blog/distribution.ex for naming details.
# Example: DNS_CLUSTER_QUERY=nodes.uwucocoa.moe
DNS_CLUSTER_QUERY=

# Shared Erlang distribution cookie — the cluster's auth secret. Every node must
# use the same value. Defaults to "cookie" when unset; on the tailnet that is
# acceptable because only tailnet members can reach the distribution port, but
# set a real value if those ports are ever exposed more widely.
RELEASE_COOKIE=

# Optional: override the auto-derived node name (default uwu_blog@<tailscale-ip>).
# Example: RELEASE_NODE=uwu_blog@100.64.1.2
RELEASE_NODE=
